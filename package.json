    "type": "git",
    "url": "git+https://github.com/nicolas-costa/DM.git"
  },
  "author": "Nícolas Costa",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nicolas-costa/DM/issues"
  },
  "homepage": "https://github.com/nicolas-costa/DM#readme",
  "dependencies": {
    "amqplib": "^0.7.0",
    "body-parser": "^1.19.0",
    "consign": "^0.1.6",
    "csv-parse": "^4.15.3",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "express-validator": "^6.10.0",
    "pg": "^8.5.1",
    "pg-hstore": "^2.3.3",
    "sequelize": "^6.5.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^26.6.3",
    "supertest": "^6.1.3"
  },
